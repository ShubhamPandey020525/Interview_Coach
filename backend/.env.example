# App
ENVIRONMENT=development
SECRET_KEY=change-me-generate-with-secrets-token-urlsafe-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite+aiosqlite:///./app.db

# LLM provider
OPENAI_API_KEY=

# Storage
MEDIA_ROOT=./media

# CORS — comma-separated; include 5174 if Vite picks another port
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174
